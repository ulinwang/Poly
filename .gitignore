# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Local secrets / OS
.env
.DS_Store
# v8: data/ is a source-code package; only runtime artifacts ignored
/data/priors_*.json
/data/wallet_personas.json
/data/personas_*.json
/data/runs/

# v8 per-experiment artifacts (track the dir + .gitkeep, ignore subtrees)
/output/*
!/output/.gitkeep

# v7-era artifact directories (kept for backwards compat)
/figures/
/tables/

.claude/

# v13 clustering feature intermediates — large, regenerable from ClickHouse
data/clustering/wallet_features_*.parquet

# v13 raw sim artifacts (parquet + llm jsonl) — too large; analysis kept separately
output_v13/**/raw/
output_v13/**/*.parquet
output_v13/**/llm_calls.jsonl
output_v13/suite_run.log

# Large publication TIFFs — regenerable from scripts/thesis_*.py
docs/v13/figures/*.tiff
