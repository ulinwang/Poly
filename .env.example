POLYMETL_RPC_URL=https://1rpc.io/matic 
#https://polygon-rpc.com
POLYMETL_CLICKHOUSE_HOST=localhost
POLYMETL_CLICKHOUSE_PORT=9000
POLYMETL_CLICKHOUSE_USER=default
POLYMETL_CLICKHOUSE_PASSWORD=
POLYMETL_CLICKHOUSE_DATABASE=polymetl
POLYMETL_CHAIN_ID=137
# 可选：只抓取某个合约地址的事件
# POLYMETL_EXCHANGE_ADDRESS=0x...
# 可选：初始/结束区块
# POLYMETL_START_BLOCK=49200000
# POLYMETL_END_BLOCK=49300000
POLYMETL_LOG_BATCH_SIZE=2000
POLYMETL_INSERT_BATCH_SIZE=5000

# DeepSeek agent simulation (src/agent.py)
POLYMETL_DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
POLYMETL_DEEPSEEK_MODEL=deepseek-v4-flash
