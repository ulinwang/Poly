{
  "name": "poly",
  "version": "0.2.0",
  "private": true,
  "description": "Poly — multi-agent simulation of decentralized prediction markets (web app monorepo)",
  "workspaces": [
    "apps/web",
    "apps/server"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "dev:server": "npm run dev --workspace apps/server",
    "build:web": "npm run build --workspace apps/web",
    "build:server": "npm run build --workspace apps/server",
    "test:server": "npm run test --workspace apps/server"
  }
}
